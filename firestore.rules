rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingListing() {
      return signedIn() && resource.data.sellerId == request.auth.uid;
    }

    function ownsNewListing() {
      return signedIn() && request.resource.data.sellerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /listings/{listingId} {
      allow read: if signedIn();
      allow create: if ownsNewListing();
      allow update: if ownsExistingListing()
        && request.resource.data.sellerId == resource.data.sellerId;
      allow delete: if ownsExistingListing();
    }
  }
}
